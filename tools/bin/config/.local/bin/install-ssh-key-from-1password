#!/usr/bin/env bash

set -euo pipefail

COMMAND_NAME="${0##*/}"
PRIVATE_KEY_REF=""
PUBLIC_KEY_REF=""
KEY_NAME="id_ed25519"
KEY_NAME_SET=false
SSH_DIR="$HOME/.ssh"
FORCE=false
GIT_SIGNING_KEY=false
SKIP_GIT=false
OP_BIN=""
GIT_BIN=""
JQ_BIN=""
TMP_DIR=""

usage() {
  cat <<EOF
Usage: $COMMAND_NAME [--private-key-ref <op-ref>] [options]

Install an SSH private key from 1Password into ~/.ssh. Git SSH signing is
configured only when the installed key is confirmed as the signing key.

Options:
  --private-key-ref <ref>  1Password secret reference for the private key
  --public-key-ref <ref>   1Password secret reference for the public key
  --key-name <name>        Output key basename in ~/.ssh (default: id_ed25519)
  --ssh-dir <path>         Output SSH directory (default: ~/.ssh)
  --git-signing-key        Configure Git SSH signing with this local key
  --force                  Replace an existing different local key
  --no-git                 Install the key without changing ~/.gitconfig
  -h, --help               Show this help

Example:
  $COMMAND_NAME \
    --private-key-ref "op://Private/SSH/GitHub/private key?ssh-format=openssh" \
    --public-key-ref "op://Private/SSH/GitHub/public key" \
    --git-signing-key

If --private-key-ref is omitted, the command lists 1Password SSH Key items,
prompts for one to use, asks for a local key basename, then asks whether the
selected key is your Git SSH signing key.
EOF
}

die() {
  printf '%s: %s\n' "$COMMAND_NAME" "$*" >&2
  exit 1
}

warn() {
  printf '%s: warning: %s\n' "$COMMAND_NAME" "$*" >&2
}

require_command() {
  local name="$1"
  local path=""

  path="$(command -v "$name" 2>/dev/null || true)"
  [[ -n "$path" ]] || die "$name is required"
  printf '%s' "$path"
}

ensure_openssh_private_key_ref() {
  local reference="$1"

  case "$reference" in
    *ssh-format=openssh*)
      printf '%s' "$reference"
      ;;
    *\?*)
      printf '%s&ssh-format=openssh' "$reference"
      ;;
    *)
      printf '%s?ssh-format=openssh' "$reference"
      ;;
  esac
}

validate_key_name() {
  [[ -n "$KEY_NAME" ]] || die 'key name cannot be empty'

  case "$KEY_NAME" in
    */* | . | ..)
      die 'key name must be a basename, not a path'
      ;;
  esac
}

parse_args() {
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --private-key-ref)
        [[ "$#" -ge 2 && -n "$2" ]] || die '--private-key-ref requires a value'
        PRIVATE_KEY_REF="$2"
        shift 2
        ;;
      --public-key-ref)
        [[ "$#" -ge 2 && -n "$2" ]] || die '--public-key-ref requires a value'
        PUBLIC_KEY_REF="$2"
        shift 2
        ;;
      --key-name)
        [[ "$#" -ge 2 && -n "$2" ]] || die '--key-name requires a value'
        KEY_NAME="$2"
        KEY_NAME_SET=true
        shift 2
        ;;
      --ssh-dir)
        [[ "$#" -ge 2 && -n "$2" ]] || die '--ssh-dir requires a value'
        SSH_DIR="$2"
        shift 2
        ;;
      --git-signing-key)
        GIT_SIGNING_KEY=true
        shift
        ;;
      --force)
        FORCE=true
        shift
        ;;
      --no-git)
        SKIP_GIT=true
        shift
        ;;
      -h | --help | help)
        usage
        exit 0
        ;;
      *)
        usage >&2
        die "unknown option: $1"
        ;;
    esac
  done
}

validate_inputs() {
  [[ -n "$PRIVATE_KEY_REF" ]] || die 'missing --private-key-ref'
  validate_key_name
}

cleanup() {
  if [[ -n "$TMP_DIR" && -d "$TMP_DIR" ]]; then
    rm -rf "$TMP_DIR"
  fi
}

read_op_file() {
  local reference="$1"
  local output_file="$2"
  local mode="$3"

  "$OP_BIN" read --out-file "$output_file" --file-mode "$mode" --force "$reference"
  chmod "$mode" "$output_file"
}

install_file() {
  local source_file="$1"
  local target_file="$2"
  local mode="$3"
  local label="$4"

  if [[ -e "$target_file" ]]; then
    if cmp -s "$source_file" "$target_file"; then
      chmod "$mode" "$target_file"
      printf '%s already installed: %s\n' "$label" "$target_file"
      return 0
    fi

    if [[ "$FORCE" != true ]]; then
      die "$target_file already exists and differs; rerun with --force to replace it"
    fi
  fi

  mv "$source_file" "$target_file"
  chmod "$mode" "$target_file"
  printf 'Installed %s: %s\n' "$label" "$target_file"
}

resolve_item_field_ref() {
  local item_json="$1"
  local field_label="$2"
  local field_ref=""

  while IFS= read -r field_ref; do
    [[ -n "$field_ref" ]] || continue
    printf '%s' "$field_ref"
    return 0
  done < <(printf '%s' "$item_json" | "$JQ_BIN" -r --arg label "$field_label" ".fields[]? | select(.label == \$label) | .reference // empty")
}

discover_private_key_ref() {
  local item_list_json=""
  local item_rows=""
  local item_count=0
  local selection=""
  local selected_index=0
  local selected_item_id=""
  local selected_item_title=""
  local selected_item_json=""
  local private_key_ref=""
  local public_key_ref=""
  local -a item_ids=()
  local -a item_titles=()

  JQ_BIN="$(require_command jq)"
  item_list_json="$($OP_BIN item list --categories "SSH Key" --format json)"
  item_rows="$(printf '%s' "$item_list_json" | "$JQ_BIN" -r '.[] | [.id, .title] | @tsv')"

  [[ -n "$item_rows" ]] || die 'no 1Password SSH Key items found'

  printf 'Available 1Password SSH Key items:\n' >&2
  while IFS=$'\t' read -r selected_item_id selected_item_title; do
    [[ -n "$selected_item_id" ]] || continue
    item_ids+=("$selected_item_id")
    item_titles+=("$selected_item_title")
    item_count=$((item_count + 1))
    printf '  %s) %s\n' "$item_count" "$selected_item_title" >&2
  done <<EOF
$item_rows
EOF

  while :; do
    printf 'Select a key [1-%s]: ' "$item_count" >&2
    if ! IFS= read -r selection; then
      die 'selection required'
    fi

    case "$selection" in
      '' | *[!0-9]*)
        warn 'enter a number from the list'
        continue
        ;;
    esac

    if (( selection < 1 || selection > item_count )); then
      warn 'selection out of range'
      continue
    fi

    selected_index=$((selection - 1))
    selected_item_id="${item_ids[$selected_index]}"
    selected_item_title="${item_titles[$selected_index]}"
    selected_item_json="$($OP_BIN item get "$selected_item_id" --format json)"
    private_key_ref="$(resolve_item_field_ref "$selected_item_json" 'private key')"
    [[ -n "$private_key_ref" ]] || die "missing private key field on selected item: $selected_item_title"
    PRIVATE_KEY_REF="$(ensure_openssh_private_key_ref "$private_key_ref")"

    public_key_ref="$(resolve_item_field_ref "$selected_item_json" 'public key')"
    if [[ -z "$PUBLIC_KEY_REF" && -n "$public_key_ref" ]]; then
      PUBLIC_KEY_REF="$public_key_ref"
    fi

    break
  done
}

prompt_for_key_name() {
  local input=""

  while :; do
    printf 'Local key basename [id_ed25519]: ' >&2
    if ! IFS= read -r input; then
      die 'key name required'
    fi

    if [[ -z "$input" ]]; then
      KEY_NAME='id_ed25519'
    else
      KEY_NAME="$input"
    fi

    KEY_NAME_SET=true

    case "$KEY_NAME" in
      */* | . | ..)
        warn 'key name must be a basename, not a path'
        continue
        ;;
    esac

    break
  done
}

prompt_for_git_signing() {
  local input=""

  while :; do
    printf 'Use this key for Git SSH signing? [y/N]: ' >&2
    if ! IFS= read -r input; then
      GIT_SIGNING_KEY=false
      return 0
    fi

    case "$input" in
      y | Y | yes | YES)
        GIT_SIGNING_KEY=true
        return 0
        ;;
      '' | n | N | no | NO)
        GIT_SIGNING_KEY=false
        return 0
        ;;
      *)
        warn 'answer y or n'
        ;;
    esac
  done
}

install_keys() {
  local private_key_path="$SSH_DIR/$KEY_NAME"
  local public_key_path="$private_key_path.pub"
  local private_tmp="$TMP_DIR/$KEY_NAME"
  local public_tmp="$TMP_DIR/$KEY_NAME.pub"

  mkdir -p "$SSH_DIR"
  chmod 700 "$SSH_DIR"

  read_op_file "$PRIVATE_KEY_REF" "$private_tmp" 0600
  install_file "$private_tmp" "$private_key_path" 0600 'private key'

  if [[ -n "$PUBLIC_KEY_REF" ]]; then
    read_op_file "$PUBLIC_KEY_REF" "$public_tmp" 0644
    install_file "$public_tmp" "$public_key_path" 0644 'public key'
  else
    warn 'no public key reference provided; skipping .pub file'
  fi

  if [[ "$GIT_SIGNING_KEY" == true && "$SKIP_GIT" != true ]]; then
    configure_git "$private_key_path"
  fi
}

configure_git() {
  local private_key_path="$1"

  GIT_BIN="$(require_command git)"

  "$GIT_BIN" config --global user.signingkey "$private_key_path"
  "$GIT_BIN" config --global commit.gpgsign true
  "$GIT_BIN" config --global tag.gpgsign true
  "$GIT_BIN" config --global tag.forceSignAnnotated true
  "$GIT_BIN" config --global gpg.format ssh
  "$GIT_BIN" config --global --unset-all gpg.ssh.program 2>/dev/null || true

  printf 'Configured Git SSH signing with local key: %s\n' "$private_key_path"
}

main() {
  parse_args "$@"

  if [[ -z "$PRIVATE_KEY_REF" ]]; then
    OP_BIN="$(require_command op)"
    discover_private_key_ref
    if [[ "$KEY_NAME_SET" != true ]]; then
      prompt_for_key_name
    fi
    if [[ "$SKIP_GIT" != true && "$GIT_SIGNING_KEY" != true ]]; then
      prompt_for_git_signing
    fi
  fi

  validate_inputs
  OP_BIN="${OP_BIN:-$(require_command op)}"
  TMP_DIR="$(mktemp -d)"
  trap cleanup EXIT

  install_keys
}

main "$@"
