#!/usr/bin/env bash
set -euo pipefail

branch="$(git branch --show-current 2>/dev/null || true)"

if [[ -z "$branch" ]]; then
  # Detached HEAD: fall back to the short commit hash
  sha="$(git rev-parse --short HEAD 2>/dev/null || true)"
  [[ -n "$sha" ]] || exit 1
  printf '\356\202\240 @%s' "$sha"
  exit 0
fi

# Worktree directories are named "repository.branch"; hide the branch when
# the worktree root's name already equals or ends with it.
toplevel="$(git rev-parse --show-toplevel 2>/dev/null || true)"
dir_name="${toplevel##*/}"
[[ -n "$dir_name" ]] || dir_name="${PWD##*/}"

normalize() {
  printf '%s' "$1" | tr '[:upper:]./-' '[:lower:]___'
}

dir_n="$(normalize "$dir_name")"
branch_n="$(normalize "$branch")"
leaf="${branch##*/}"
leaf_n="$branch_n"
[[ "$leaf" == "$branch" ]] || leaf_n="$(normalize "$leaf")"

case "$dir_n" in
  "$branch_n" | *"_$branch_n" | "$leaf_n" | *"_$leaf_n") exit 1 ;;
esac

printf '\356\202\240 %s' "$branch"
