#!/usr/bin/env bash

set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/.dotfiles}"
BACKUP_DIR="${RAYCAST_BACKUP_DIR:-$DOTFILES/tools/raycast/backups}"
EXPORT_DIR="${RAYCAST_EXPORT_DIR:-$HOME/Downloads}"
EXPORT_DEEPLINK_PATH="extensions/raycast/raycast/export-settings-data"
EXPORT_COMMAND_NAME="Export Settings & Data"
DEFAULT_TIMEOUT_SECONDS=300

usage() {
	cat <<'USAGE'
Usage: raycast-config <command> [args]

Commands:
  status                 Show backup directory, count, and newest backup
  list                   List Raycast backups newest first
  path [latest|file]     Print the absolute path for a backup
  backup [options] [file] Launch Raycast export or copy an exported .rayconfig
  restore [latest|file]  Open a backup in Raycast for manual import
  help                   Show this help

Environment:
  RAYCAST_BACKUP_DIR       Override backup directory
  RAYCAST_EXPORT_DIR       Override directory watched for Raycast exports
  RAYCAST_APP_NAME         Override app target (Raycast or Raycast Beta)
  RAYCAST_EXPORT_PASSWORD  Passphrase for encrypted exports
  RAYCAST_EXPORT_PASSWORD_CMD
                           Command that prints the export passphrase
  RAYCAST_CONFIG_DRY_RUN   Print targets without opening Raycast

Raycast exports may include private app settings. Keep sensitive backups in
your private dotfiles layer if needed.

Backup options:
  --export-dir <dir>   Directory where Raycast writes exports
  --timeout <seconds>  Seconds to wait for a new export (default: 300)
  --no-open            Do not open Raycast, only wait for a new export
  --manual             Open export flow but do not press buttons
  --force              Replace an existing stored backup with the same name
USAGE
}

die() {
	printf 'raycast-config: %s\n' "$*" >&2
	exit 1
}

ensure_backup_dir() {
	mkdir -p "$BACKUP_DIR"
}

raycast_files() {
	ensure_backup_dir
	find "$BACKUP_DIR" -maxdepth 1 -type f -name '*.rayconfig' -exec stat -f '%m %N' {} + 2>/dev/null |
		sort -rn
}

newest_export() {
	[[ -d "$EXPORT_DIR" ]] || die "export directory not found: $EXPORT_DIR"

	find "$EXPORT_DIR" -maxdepth 1 -type f -name 'Raycast*.rayconfig' -exec stat -f '%m %N' {} + 2>/dev/null |
		sort -rn |
		sed -n '1s/^[0-9]* //p'
}

newest_export_since() {
	local start_time="$1"
	local newest_path=""
	local newest_modified=0
	local file modified

	[[ -d "$EXPORT_DIR" ]] || die "export directory not found: $EXPORT_DIR"

	while IFS= read -r -d '' file; do
		modified="$(stat -f '%m' "$file")"
		if ((modified >= start_time && modified > newest_modified)); then
			newest_modified="$modified"
			newest_path="$file"
		fi
	done < <(find "$EXPORT_DIR" -maxdepth 1 -type f -name 'Raycast*.rayconfig' -print0)

	printf '%s\n' "$newest_path"
}

file_is_stable() {
	local file="$1"
	local size_before modified_before size_after modified_after

	[[ -f "$file" ]] || return 1
	size_before="$(stat -f '%z' "$file")"
	modified_before="$(stat -f '%m' "$file")"
	sleep 1
	[[ -f "$file" ]] || return 1
	size_after="$(stat -f '%z' "$file")"
	modified_after="$(stat -f '%m' "$file")"

	[[ "$size_before" == "$size_after" && "$modified_before" == "$modified_after" ]]
}

raycast_app_name() {
	if [[ -n "${RAYCAST_APP_NAME:-}" ]]; then
		printf '%s\n' "$RAYCAST_APP_NAME"
		return
	fi

	if [[ -d "/Applications/Raycast Beta.app" ]]; then
		printf 'Raycast Beta\n'
		return
	fi

	printf 'Raycast\n'
}

raycast_export_deeplink() {
	local app_name="$1"

	case "$app_name" in
	Raycast\ Beta)
		printf 'raycast-x://%s\n' "$EXPORT_DEEPLINK_PATH"
		;;
	*)
		printf 'raycast://%s\n' "$EXPORT_DEEPLINK_PATH"
		;;
	esac
}

raycast_needs_search_launch() {
	local app_name="$1"

	[[ "$app_name" == "Raycast Beta" ]]
}

raycast_export_password_configured() {
	[[ -n "${RAYCAST_EXPORT_PASSWORD:-}" || -n "${RAYCAST_EXPORT_PASSWORD_CMD:-}" ]]
}

raycast_export_password() {
	local password=""

	if [[ -n "${RAYCAST_EXPORT_PASSWORD_CMD:-}" ]]; then
		password="$(bash -c "$RAYCAST_EXPORT_PASSWORD_CMD")" || die "export password command failed"
	elif [[ -n "${RAYCAST_EXPORT_PASSWORD:-}" ]]; then
		password="$RAYCAST_EXPORT_PASSWORD"
	fi

	if [[ -n "$password" ]]; then
		[[ "$password" != *$'\n'* ]] || die "export password must be a single line"
		((${#password} >= 8)) || die "export password must be at least 8 characters"
	fi

	printf '%s\n' "$password"
}

open_export_flow() {
	local app_name="$1"
	local export_deeplink="$2"

	if raycast_needs_search_launch "$app_name"; then
		open -a "$app_name"
		osascript - "$app_name" "$EXPORT_COMMAND_NAME" <<'APPLESCRIPT'
on run argv
  set raycastApp to item 1 of argv
  set exportCommand to item 2 of argv

  tell application raycastApp to activate
  delay 0.4

  tell application "System Events"
    if not (exists process raycastApp) then error raycastApp & " process was not found"

    tell process raycastApp
      set frontmost to true
      delay 0.2
    end tell

    keystroke "a" using {command down}
    delay 0.05
    keystroke exportCommand
    delay 0.15
    key code 36
  end tell
end run
APPLESCRIPT
		return
	fi

	open "$export_deeplink"
}

wait_for_new_export() {
	local start_time="$1"
	local timeout_seconds="$2"
	local deadline candidate

	deadline="$((start_time + timeout_seconds))"

	while (($(date +%s) <= deadline)); do
		candidate="$(newest_export_since "$start_time")"
		if [[ -n "$candidate" ]] && file_is_stable "$candidate"; then
			printf '%s\n' "$candidate"
			return
		fi
		sleep 1
	done

	die "timed out waiting for a new Raycast export in $EXPORT_DIR"
}

copy_backup() {
	local source_file="$1"
	local force="$2"

	[[ -f "$source_file" ]] || die "file not found: $source_file"
	[[ "$source_file" == *.rayconfig ]] || die "file must end with .rayconfig"

	ensure_backup_dir

	local dest
	dest="$BACKUP_DIR/$(basename "$source_file")"

	if [[ -e "$dest" && "$force" != true ]]; then
		die "backup already exists: $dest"
	fi

	cp "$source_file" "$dest"
	printf 'Copied backup: %s\n' "$dest"
}

automate_export_flow() {
	local export_dir="$1"
	local app_name="$2"
	local confirm_command="$3"
	local export_password="$4"

	RAYCAST_RESOLVED_EXPORT_PASSWORD="$export_password" osascript - "$export_dir" "$app_name" "$confirm_command" <<'APPLESCRIPT'
on run argv
  set exportDir to item 1 of argv
  set raycastApp to item 2 of argv
  set shouldConfirmCommand to item 3 of argv
  set exportPassword to system attribute "RAYCAST_RESOLVED_EXPORT_PASSWORD"
  set previousClipboard to ""
  set shouldRestoreClipboard to false

  try
    set previousClipboard to the clipboard as text
    set shouldRestoreClipboard to true
  end try

  try
    tell application raycastApp to activate
    delay 0.4

    tell application "System Events"
      if not (exists process raycastApp) then error raycastApp & " process was not found"

      tell process raycastApp
        set frontmost to true
        delay 0.15

        if shouldConfirmCommand is "true" then
          -- Confirmation dialog: "Run Command" / "Always Run Command".
          key code 36
          delay 0.15
        end if

        -- Export Settings & Data screen: press the focused/default Export button.
        key code 36
        delay 0.4

        if exportPassword is not "" then
          set the clipboard to exportPassword
          keystroke "v" using {command down}
          delay 0.1
          key code 36
          delay 1.5
        end if
      end tell

      -- Save panel: choose the export directory explicitly, then confirm Export.
      keystroke "g" using {command down, shift down}
      delay 0.2
      set the clipboard to exportDir
      keystroke "v" using {command down}
      key code 36
      delay 0.2
      key code 36
    end tell
  on error errorMessage number errorNumber
    if shouldRestoreClipboard then set the clipboard to previousClipboard
    error errorMessage number errorNumber
  end try

  if shouldRestoreClipboard then set the clipboard to previousClipboard
end run
APPLESCRIPT
}

newest_backup() {
	raycast_files | sed -n '1s/^[0-9]* //p'
}

resolve_backup() {
	local selector="${1:-latest}"

	case "$selector" in
	latest | "")
		local latest
		latest="$(newest_backup)"
		[[ -n "$latest" ]] || die "no .rayconfig backups found in $BACKUP_DIR"
		printf '%s\n' "$latest"
		;;
	*/*)
		[[ -f "$selector" ]] || die "backup not found: $selector"
		printf '%s\n' "$selector"
		;;
	*)
		local candidate="$BACKUP_DIR/$selector"
		[[ -f "$candidate" ]] || die "backup not found: $selector"
		printf '%s\n' "$candidate"
		;;
	esac
}

cmd_status() {
	ensure_backup_dir

	local count latest age now modified
	count="$(find "$BACKUP_DIR" -maxdepth 1 -type f -name '*.rayconfig' | wc -l | tr -d ' ')"
	latest="$(newest_backup || true)"

	printf 'Backup directory: %s\n' "$BACKUP_DIR"
	printf 'Backups: %s\n' "$count"

	if [[ -n "$latest" ]]; then
		now="$(date +%s)"
		modified="$(stat -f '%m' "$latest")"
		age="$(((now - modified) / 86400))"
		printf 'Newest: %s\n' "$(basename "$latest")"
		printf 'Age: %s day(s)\n' "$age"
	else
		printf 'Newest: none\n'
	fi
}

cmd_list() {
	local files
	files="$(raycast_files)"
	[[ -n "$files" ]] || die "no .rayconfig backups found in $BACKUP_DIR"
	printf '%s\n' "$files" | while IFS= read -r line; do
		printf '%s\n' "${line#* }"
	done
}

cmd_path() {
	resolve_backup "${1:-latest}"
}

cmd_backup() {
	local source_file=""
	local timeout_seconds="$DEFAULT_TIMEOUT_SECONDS"
	local open_raycast=true
	local automate=true
	local force=false
	local app_name=""
	local export_deeplink=""
	local confirm_command=true
	local export_password=""

	while [[ $# -gt 0 ]]; do
		case "$1" in
		--export-dir)
			[[ -n "${2:-}" ]] || die "--export-dir requires a directory"
			EXPORT_DIR="$2"
			shift 2
			;;
		--timeout)
			[[ -n "${2:-}" ]] || die "--timeout requires seconds"
			[[ "$2" =~ ^[0-9]+$ ]] || die "--timeout must be a number"
			timeout_seconds="$2"
			shift 2
			;;
		--no-open)
			open_raycast=false
			automate=false
			shift
			;;
		--manual)
			automate=false
			shift
			;;
		--force)
			force=true
			shift
			;;
		-h | --help)
			usage
			return
			;;
		--*)
			die "unknown backup option: $1"
			;;
		*)
			[[ -z "$source_file" ]] || die "backup accepts only one file"
			source_file="$1"
			shift
			;;
		esac
	done

	if [[ -n "$source_file" ]]; then
		copy_backup "$source_file" "$force"
		return
	fi

	[[ -d "$EXPORT_DIR" ]] || die "export directory not found: $EXPORT_DIR"
	app_name="$(raycast_app_name)"
	export_deeplink="$(raycast_export_deeplink "$app_name")"
	if raycast_needs_search_launch "$app_name"; then
		confirm_command=false
	fi

	local start_time
	start_time="$(date +%s)"

	if [[ "$open_raycast" == true ]]; then
		if [[ "${RAYCAST_CONFIG_DRY_RUN:-}" == 1 ]]; then
			printf 'Would automate app: %s\n' "$app_name"
			if raycast_needs_search_launch "$app_name"; then
				printf 'Would search command: %s\n' "$EXPORT_COMMAND_NAME"
			else
				printf 'Would open: %s\n' "$export_deeplink"
			fi
			if raycast_export_password_configured; then
				printf 'Would use configured export passphrase.\n'
			fi
			printf 'Would wait for a new Raycast export in: %s\n' "$EXPORT_DIR"
			return
		fi

		if [[ "$automate" == true ]]; then
			if raycast_needs_search_launch "$app_name" && ! raycast_export_password_configured; then
				die "Raycast Beta export requires a passphrase; set RAYCAST_EXPORT_PASSWORD_CMD or RAYCAST_EXPORT_PASSWORD"
			fi
			export_password="$(raycast_export_password)"
		fi

		open_export_flow "$app_name" "$export_deeplink"
		printf 'Opened Raycast export flow.\n'

		if [[ "$automate" == true ]]; then
			printf 'Pressing Raycast export buttons with AppleScript...\n'
			automate_export_flow "$EXPORT_DIR" "$app_name" "$confirm_command" "$export_password"
		else
			printf 'Complete the Raycast export manually.\n'
		fi
	fi

	printf 'Waiting up to %s seconds for a new Raycast export in %s...\n' "$timeout_seconds" "$EXPORT_DIR"
	source_file="$(wait_for_new_export "$start_time" "$timeout_seconds")"
	copy_backup "$source_file" "$force"
}

cmd_restore() {
	local backup
	backup="$(resolve_backup "${1:-latest}")"

	[[ "$backup" == *.rayconfig ]] || die "backup must end with .rayconfig"

	if [[ "${RAYCAST_CONFIG_DRY_RUN:-}" == 1 ]]; then
		printf 'Would open: %s\n' "$backup"
		return
	fi

	open "$backup"
	printf 'Opened Raycast import: %s\n' "$backup"
	printf 'Confirm the import manually in Raycast.\n'
}

main() {
	local command="${1:-help}"
	shift || true

	case "$command" in
	status) cmd_status "$@" ;;
	list) cmd_list "$@" ;;
	path) cmd_path "$@" ;;
	backup) cmd_backup "$@" ;;
	restore) cmd_restore "$@" ;;
	help | -h | --help) usage ;;
	*)
		usage >&2
		die "unknown command: $command"
		;;
	esac
}

main "$@"
