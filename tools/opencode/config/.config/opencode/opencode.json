{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "formatter": true,
  "lsp": true,
  "share": "disabled",
  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "Expo": {
      "type": "remote",
      "url": "https://mcp.expo.dev/mcp",
      "enabled": false
    },
    "Figma Desktop": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--user-data-dir",
        "{env:HOME}/.local/state/opencode/chrome-devtools-mcp"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--user-data-dir",
        "{env:HOME}/.local/state/opencode/playwright-mcp"
      ],
      "enabled": false
    }
  }
}
