# Keep redirects convenient while limiting accidental redirect loops.
show-error
location
max-redirs = 10

# Follow only HTTP(S) redirects, even if a server suggests another protocol.
proto-redir = -all,http,https

# Avoid hanging forever on dead networks or slow endpoints.
connect-timeout = 10

# Retry brief transient failures without masking persistent problems.
retry = 2
retry-delay = 1
retry-max-time = 60

# Keep credentials out of URLs and avoid overwriting existing files.
disallow-username-in-url
no-clobber

# Remove partial downloads and keep terminal output readable.
remove-on-error
styled-output
