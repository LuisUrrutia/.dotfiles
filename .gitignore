.DS_Store
__pycache__/
docs/superpowers/
/docs/
.omo/
.sisyphus/
*.bak

# machine-local legacy git identity, kept on disk but untracked
tools/git/config/.gitconfig

# OpenCode generated state
tools/opencode/config/.config/opencode/.gitignore
tools/opencode/config/.config/opencode/node_modules/
tools/opencode/config/.config/opencode/package.json
tools/opencode/config/.config/opencode/package-lock.json
tools/opencode/config/.config/opencode/bun.lock
tools/opencode/config/.config/opencode/oh-my-openagent.json
tools/opencode/config/.config/opencode/oh-my-openagent.jsonc
tools/opencode/config/.config/opencode/oh-my-openagent.json.bak.*
tools/opencode/config/.config/opencode/oh-my-openagent.jsonc.bak.*
tools/opencode/config/.config/opencode/oh-my-openagent.json.migrations.json
tools/opencode/config/.config/opencode/oh-my-opencode.json*
tools/opencode/config/.config/opencode/skills/*

# Pi generated state (skills installed via npx skills)
tools/pi/config/.pi/agent/.agents/
tools/pi/config/.pi/agent/skills-lock.json

# cc-safety-net runtime state (guard: must never land in the stow package;
# rulebooks under rules/ ARE tracked, only the lock file is generated)
tools/cc-safety-net/config/.cc-safety-net/cache/
tools/cc-safety-net/config/.cc-safety-net/logs/
tools/cc-safety-net/config/.cc-safety-net/rules/rule.lock

# Stray HOME/XDG/toolchain state accidentally captured into a stow package
# (created when a process runs with HOME pointed at tools/*/config/).
# Keep .local/bin (tracked) — ignore only generated XDG/toolchain dirs.
tools/*/config/.cache/
tools/*/config/.cargo/
tools/*/config/.rustup/
tools/*/config/.local/share/
tools/*/config/.local/state/
